---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogAggregators, extraBloggers } from '../config/site';
---

<BaseLayout title="博客圈子">
  <h1 class="page-title">✦ 博客圈子</h1>
  <p class="page-subtitle">收藏优质博客聚合平台与游戏群演博主</p>

  <div class="nes-container is-dark">
    <div class="circle-intro">
      <p>这里收录了优质博客聚合平台，以及在《我的博客》游戏中登场的群演博主。</p>
      <p style="margin-top: 0.5rem; color: var(--text-muted); font-size: 0.85rem;">
        共收录 <strong class="nes-text is-warning">{blogAggregators.length}</strong> 个聚合平台 ·
        <strong class="nes-text is-error">{extraBloggers.length}</strong> 位群演博主
      </p>
    </div>
  </div>

  <h2 class="section-title" style="margin-top: 2rem;">
    <span class="text-accent">■</span> 群演博客
  </h2>
  <p class="section-subtitle">在《我的博客》游戏中「博客江湖」联盟登场的博主们 ——「每一个独立博客，都是一个独一无二的世界。」向群演博主们表示深深的感谢！🙏 <a href="https://www.suiyan.cc/blog/20260717112354" target="_blank" style="color:var(--accent);">我要报名群演 →</a></p>
  <div class="extra-grid">
    {extraBloggers.map((b) => (
      <div class="nes-container is-dark extra-card">
        <a href={b.url} target="_blank" class="extra-link">
          <h3 class="extra-name">{b.blog}</h3>
          <p class="extra-desc"><span class="extra-author">@{b.author}</span> · <span class:list={['extra-type', b.type === '编程' ? 'type-code' : b.type === '文学' ? 'type-lit' : 'type-mix']}>{b.type}</span> · Lv.{b.lv}</p>
          <span class="extra-url">{b.url}</span>
        </a>
      </div>
    ))}
  </div>

  <h2 class="section-title" style="margin-top: 2rem;">
    <span class="text-accent">■</span> 博客聚合平台
  </h2>
  <p class="section-subtitle">发现更多独立博客的入口，如果你也希望自己的博客聚合平台出现在这里，欢迎<a href="https://github.com/bosichong/MyBlogGame" target="_blank">联系我</a></p>
  <div class="aggregator-grid">
    {blogAggregators.map((a) => (
      <div class="nes-container is-dark aggregator-card">
        <a href={a.url} target="_blank" class="aggregator-link">
          <h3 class="aggregator-name">{a.name}</h3>
          <p class="aggregator-desc">{a.desc}</p>
          <span class="aggregator-url">{a.url}</span>
        </a>
      </div>
    ))}
  </div>

  <div class="nes-container is-dark" style="margin-top: 1.5rem;">
    <div class="submit-section">
      <p class="nes-text is-primary" style="font-family: 'Press Start 2P', monospace; font-size: 0.65rem;">
        📡 推荐博客
      </p>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">
        如果你有推荐的优质独立博客，欢迎在 GitHub 提交 Issue 或 PR。
      </p>
      <a href="https://github.com/bosichong/MyBlogGame" target="_blank" class="nes-btn" style="margin-top: 0.8rem;">
        推荐博客
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .circle-intro p {
    line-height: 1.6;
  }

  .circle-intro a {
    color: var(--accent);
  }

  .section-subtitle {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: -1rem;
    margin-bottom: 1rem;
  }

  .aggregator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1rem;
  }

  .aggregator-card {
    padding: 1rem;
  }

  .aggregator-link {
    text-decoration: none;
    display: block;
  }

  .aggregator-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .aggregator-desc {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.5;
    margin-bottom: 0.4rem;
  }

  .aggregator-url {
    font-size: 0.7rem;
    color: var(--text-muted);
    word-break: break-all;
    display: block;
  }

  .submit-section {
    text-align: center;
    padding: 1rem;
  }

  .extra-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .extra-card {
    padding: 1rem;
  }

  .extra-link {
    text-decoration: none;
    display: block;
  }

  .extra-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    color: #fff;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .extra-desc {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.5;
    margin-bottom: 0.4rem;
  }

  .extra-author {
    color: var(--accent);
  }

  .extra-type {
    font-size: 0.85rem;
  }

  .type-code {
    color: #88d0ff;
  }

  .type-lit {
    color: #ff9e9e;
  }

  .type-mix {
    color: #a0e0a0;
  }

  .extra-url {
    font-size: 0.7rem;
    color: var(--text-muted);
    word-break: break-all;
    display: block;
  }

  @media (max-width: 768px) {
    .aggregator-grid {
      grid-template-columns: 1fr 1fr;
    }

    .extra-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .aggregator-grid {
      grid-template-columns: 1fr;
    }

    .extra-grid {
      grid-template-columns: 1fr;
    }
  }
</style>


