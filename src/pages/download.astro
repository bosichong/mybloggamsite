---
import BaseLayout from '../layouts/BaseLayout.astro';

const platforms = [
  { name: 'Windows', icon: '🪟', status: '开发中', note: '预计暑假发布试玩版本', class: 'is-warning' },
  { name: 'macOS', icon: '🍎', status: '开发中', note: '预计暑假发布试玩版本', class: 'is-warning' },
  { name: 'Linux', icon: '🐧', status: '开发中', note: '预计暑假发布试玩版本', class: 'is-warning' },
];
---

<BaseLayout title="下载游戏">
  <h1 class="page-title">⬇ 下载游戏</h1>
  <p class="page-subtitle">选择适合你的平台，开始你的博客之旅</p>

  <div class="nes-container is-dark with-title">
    <p class="title">开发进度</p>
    <div class="progress-info">
      <p>当前版本：<span class="nes-text is-warning">Alpha 开发中</span></p>
      <p>预计发布：<span class="nes-text is-primary">2026 年暑假试玩版</span></p>
    </div>
    <div class="nes-progress is-rounded">
      <div class="nes-progress-bar" style="width: 75%;">
        <span class="progress-text">75%</span>
      </div>
    </div>
  </div>

  <div class="download-grid">
    {platforms.map((p) => (
      <div class="nes-container is-dark">
        <div class="platform-card">
          <span class="platform-icon">{p.icon}</span>
          <h3 class="platform-name">{p.name}</h3>
          <span class={`nes-text ${p.class}`}>{p.status}</span>
          <p class="platform-note">{p.note}</p>
          <button class="nes-btn is-disabled" disabled>暂未开放</button>
        </div>
      </div>
    ))}
  </div>

  <div class="nes-container is-dark with-title" style="margin-top: 1.5rem;">
    <p class="title">运行方式</p>
    <div class="nes-list is-disc">
      <p>1. 确保已安装 Godot 4.x 引擎</p>
      <p>2. 克隆或下载项目源码</p>
      <p>3. 使用 Godot 打开项目文件夹</p>
      <p>4. 运行项目即可开始游戏</p>
    </div>
    <div class="dev-link" style="margin-top: 1rem;">
      <a href="https://github.com/bosichong/MyBlogGame" target="_blank" class="nes-btn is-primary">获取源码 (GitHub)</a>
    </div>
    <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--text-muted;">
      本项目基于 <a href="https://github.com/bosichong/MyBlogGame/blob/main/LICENSE" target="_blank" style="color: var(--accent);">MIT 开源协议</a>发布，欢迎 Fork、修改和分发。
    </p>
  </div>

  <div class="nes-container is-dark with-title" style="margin-top: 1.5rem;">
    <p class="title">系统要求</p>
    <div class="specs">
      <div class="spec-row">
        <span class="spec-label">操作系统</span>
        <span class="spec-value">Windows 7+ / macOS 10.13+ / Linux</span>
      </div>
      <div class="spec-row">
        <span class="spec-label">处理器</span>
        <span class="spec-value">双核 2.0 GHz 以上</span>
      </div>
      <div class="spec-row">
        <span class="spec-label">内存</span>
        <span class="spec-value">2 GB RAM</span>
      </div>
      <div class="spec-row">
        <span class="spec-label">显卡</span>
        <span class="spec-value">支持 OpenGL 3.3 / Vulkan 1.0</span>
      </div>
      <div class="spec-row">
        <span class="spec-label">存储</span>
        <span class="spec-value">约 200 MB 可用空间</span>
      </div>
      <div class="spec-row">
        <span class="spec-label">引擎</span>
        <span class="spec-value">Godot 4.7</span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .progress-info {
    margin-bottom: 1rem;
  }
  .progress-info p {
    margin-bottom: 0.3rem;
  }

  .nes-progress {
    height: 30px;
    background: #333;
  }

  .nes-progress-bar {
    background: var(--accent);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', monospace;
    font-size: 0.65rem;
    color: #fff;
  }

  .progress-text {
    text-shadow: 1px 1px 0 #000;
  }

  .download-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .download-grid .nes-container {
    padding: 1.5rem;
  }

  .platform-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .platform-icon {
    font-size: 3rem;
  }

  .platform-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    color: #fff;
  }

  .platform-note {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .platform-card .nes-btn {
    margin-top: 0.5rem;
  }

  .specs {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .spec-row {
    display: flex;
    gap: 1rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .spec-label {
    min-width: 100px;
    color: var(--accent);
    font-size: 0.85rem;
  }

  .spec-value {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  @media (max-width: 640px) {
    .download-grid {
      grid-template-columns: 1fr;
    }

    .spec-row {
      flex-direction: column;
      gap: 0.2rem;
    }

    .spec-label {
      min-width: auto;
    }
  }
</style>
