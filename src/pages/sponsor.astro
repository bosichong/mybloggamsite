---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sponsorMethods, sponsorRecords } from '../config/site';
---

<BaseLayout title="赞助支持">
  <h1 class="page-title">♥ 赞助支持</h1>
  <p class="page-subtitle">支持独立游戏开发，让好游戏走得更远</p>

  <div class="nes-container is-dark">
    <div class="sponsor-intro">
      <p>《我的博客》是一款完全免费的开源游戏，由 J.sky<strong class="nes-text is-primary">Github ID : bosichong</strong> 独立开发。</p>
      <p>如果你喜欢这款游戏，欢迎通过以下方式赞助支持。你的支持将帮助我投入更多时间完善游戏内容，提升游戏品质。</p>
      <p>另外，如果你赞赏了我，希望在本页留下你的博客或网站地址，可以联系我。285911#gmail.commm</p>
    </div>
  </div>

  <h2 class="section-title" style="margin-top: 2rem;"><span class="text-accent">■</span> 赞助方式</h2>
  <div class="sponsor-methods">
    {sponsorMethods.map((m) => (
      <div class="nes-container is-dark">
        <div class="method-card">
          <span class="method-icon">{m.icon}</span>
          <h3 class="method-title">{m.title}</h3>
          <p class="method-desc">{m.desc}</p>
          {m.qrcode ? (
            <button class="nes-btn is-success" onclick="document.getElementById('qrcode-modal').classList.add('show')">扫码赞赏</button>
          ) : (
            <a
              href={m.link}
              class={['nes-btn', m.btnClass].join(' ')}
              target="_blank"
            >
              {m.status}
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="modal-overlay" id="qrcode-modal" onclick="if (event.target === this) this.classList.remove('show')">
    <div class="nes-container is-dark modal-content">
      <div class="modal-close" onclick="document.getElementById('qrcode-modal').classList.remove('show')">✕</div>
      <p class="nes-text is-primary" style="font-family:'Press Start 2P',monospace;font-size:0.7rem;text-align:center;margin-bottom:1rem;">☕ 扫码请喝咖啡</p>
      <img src="https://www.suiyan.cc/assets/images/zs.jpg" alt="赞赏码" class="modal-qrcode" />
      <p style="text-align:center;color:var(--text-muted);font-size:0.85rem;margin-top:0.8rem;">感谢你的支持！</p>
    </div>
  </div>

  <h2 class="section-title" style="margin-top: 2rem;"><span class="text-accent">■</span> 赞赏记录</h2>
  <div class="records-list">
    {sponsorRecords.map((r) => (
      <div class="nes-container is-dark record-card">
        <div class="record-row record-amount">
          <span class="record-label">收款金额</span>
          <span class="record-value">{r.amount}</span>
        </div>
        <div class="record-row">
          <span class="record-label">来自</span>
          <span class="record-value">{r.from}</span>
        </div>
        <div class="record-row">
          <span class="record-label">付款方留言</span>
          <span class="record-value">{r.message}</span>
        </div>
        <div class="record-row">
          <span class="record-label">博客</span>
          <span class="record-value">
            {r.blog && r.blog !== '#' ? (
              <a href={r.blog} target="_blank" class="record-link">{r.blog}</a>
            ) : (
              <span class="record-muted">未提供</span>
            )}
          </span>
        </div>
        <div class="record-row">
          <span class="record-label">到账时间</span>
          <span class="record-value record-time">{r.time}</span>
        </div>
      </div>
    ))}
  </div>

  <div class="nes-container is-dark" style="margin-top: 1.5rem;">
    <div class="thank-you">
      <p class="nes-text is-primary" style="font-family: 'Press Start 2P', monospace; font-size: 0.7rem;">
        感谢每一位支持者！
      </p>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">
        所有赞助资金将用于游戏开发、美术资源采购和服务器维护。
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .sponsor-intro p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .sponsor-methods {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .sponsor-methods .nes-container {
    padding: 1.2rem;
  }

  .sponsor-methods .nes-container:has(.qrcode-img) {
    grid-column: span 1;
  }

  .method-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .method-icon {
    font-size: 2.5rem;
  }

  .method-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.8rem;
    color: #fff;
  }

  .method-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .modal-overlay.show {
    display: flex;
  }

  .modal-content {
    max-width: 280px;
    width: 100%;
    position: relative;
    text-align: center;
    padding: 1.5rem;
  }

  .modal-close {
    position: absolute;
    top: 0.5rem;
    right: 0.8rem;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .modal-close:hover {
    color: var(--accent);
  }

  .modal-qrcode {
    width: 180px;
    height: 180px;
    image-rendering: pixelated;
    border: 2px solid var(--border-color);
  }

  .records-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .record-card {
    padding: 1rem;
  }

  .record-row {
    display: flex;
    gap: 0.5rem;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--border-color);
    font-size: 0.9rem;
  }

  .record-row:last-child {
    border-bottom: none;
  }

  .record-label {
    min-width: 6rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .record-value {
    color: #fff;
  }

  .record-amount .record-value {
    color: #f7d44a;
    font-weight: bold;
    font-size: 1.1rem;
  }

  .record-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    word-break: break-all;
  }
  .record-link:hover {
    color: #fff;
  }

  .record-muted {
    color: var(--text-muted);
    font-style: italic;
  }

  .record-time {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .thank-you {
    text-align: center;
    padding: 1rem;
  }

  @media (max-width: 640px) {
    .sponsor-methods {
      grid-template-columns: 1fr;
    }
  }
</style>
