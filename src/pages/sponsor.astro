---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sponsorMethods, sponsorTiers, sponsorsByTier } from '../config/site';
---

<BaseLayout title="赞助支持">
  <h1 class="page-title">♥ 赞助支持</h1>
  <p class="page-subtitle">支持独立游戏开发，让好游戏走得更远</p>

  <div class="nes-container is-dark">
    <div class="sponsor-intro">
      <p>《我的博客》是一款完全免费的开源游戏，由 J.sky<strong class="nes-text is-primary">Github ID : bosichong</strong> 独立开发。</p>
      <p>如果你喜欢这款游戏，欢迎通过以下方式赞助支持。你的支持将帮助我投入更多时间完善游戏内容，提升游戏品质。</p>
    </div>
  </div>

  <h2 class="section-title" style="margin-top: 2rem;"><span class="text-accent">■</span> 赞助方式</h2>
  <div class="sponsor-methods">
    {sponsorMethods.map((m) => (
      <div class="nes-container is-dark">
        <div class="method-card">
          <span class="method-icon">{m.icon}</span>
          <h3 class="method-title">{m.title}</h3>
          <p class="method-desc">{m.desc}</p>
          {m.qrcode ? (
            <button class="nes-btn is-success" onclick="document.getElementById('qrcode-modal').classList.add('show')">扫码赞赏</button>
          ) : (
            <a
              href={m.link}
              class={['nes-btn', m.btnClass].join(' ')}
              target="_blank"
            >
              {m.status}
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="modal-overlay" id="qrcode-modal" onclick="if (event.target === this) this.classList.remove('show')">
    <div class="nes-container is-dark modal-content">
      <div class="modal-close" onclick="document.getElementById('qrcode-modal').classList.remove('show')">✕</div>
      <p class="nes-text is-primary" style="font-family:'Press Start 2P',monospace;font-size:0.7rem;text-align:center;margin-bottom:1rem;">☕ 扫码请喝咖啡</p>
      <img src="https://www.suiyan.cc/assets/images/zs.jpg" alt="赞赏码" class="modal-qrcode" />
      <p style="text-align:center;color:var(--text-muted);font-size:0.85rem;margin-top:0.8rem;">感谢你的支持！</p>
    </div>
  </div>

  <h2 class="section-title" style="margin-top: 2rem;"><span class="text-accent">■</span> 赞助档位</h2>
  <div class="tier-grid">
    {sponsorTiers.map((t) => (
      <div class="nes-container is-dark">
        <div class="tier-card">
          <span class={`nes-text ${t.color}`} style="font-family: 'Press Start 2P', monospace; font-size: 0.65rem;">
            {t.name}
          </span>
          <p class="tier-amount">{t.amount}</p>
        </div>
      </div>
    ))}
  </div>

  <h2 class="section-title" style="margin-top: 2rem;"><span class="text-accent">■</span> 赞助者名单</h2>
  <div class="sponsor-tiers">
    {sponsorTiers.map((tier) => {
      const members = sponsorsByTier[tier.key] || [];
      return (
        <div class="nes-container is-dark tier-group">
          <div class="tier-group-header">
            <span class={`nes-text ${tier.color}`} style="font-family:'Press Start 2P',monospace;font-size:0.7rem;">{tier.name} ({tier.amount})</span>
            <span class="tier-count">{members.length > 0 ? `${members.length} 人` : '虚位以待'}</span>
          </div>
          {members.length > 0 ? (
            <div class="sponsor-list">
              {members.map((s) => (
                <div class="sponsor-member">
                  <div class="sponsor-item">
                    <div class="sponsor-avatar">{s.name[0]}</div>
                    <div class="sponsor-info">
                      <h4 class="sponsor-name">{s.url ? <a href={s.url} target="_blank" class="sponsor-link">{s.name}</a> : s.name}</h4>
                      <span class="sponsor-role">{s.role}</span>
                      <p class="sponsor-desc">{s.desc}</p>
                      {s.amount && <span class="sponsor-amount">{s.amount}</span>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="tier-group-empty">
              <span class="nes-text is-disabled" style="font-size:0.85rem;">暂无赞助者，期待你的支持</span>
            </div>
          )}
        </div>
      );
    })}
    <div class="nes-container is-dark tier-group">
      <div class="tier-group-header">
        <span class="nes-text is-disabled" style="font-family:'Press Start 2P',monospace;font-size:0.7rem;">其他</span>
        <span class="tier-count">{sponsorsByTier.other.length} 人</span>
      </div>
      <div class="sponsor-list">
        {sponsorsByTier.other.map((s) => (
          <div class="sponsor-member">
            <div class="sponsor-item">
              <div class="sponsor-avatar">{s.name[0]}</div>
              <div class="sponsor-info">
                <h4 class="sponsor-name">{s.url ? <a href={s.url} target="_blank" class="sponsor-link">{s.name}</a> : s.name}</h4>
                <span class="sponsor-role">{s.role}</span>
                <p class="sponsor-desc">{s.desc}</p>
                {s.amount && <span class="sponsor-amount">{s.amount}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="nes-container is-dark" style="margin-top: 1.5rem;">
    <div class="thank-you">
      <p class="nes-text is-primary" style="font-family: 'Press Start 2P', monospace; font-size: 0.7rem;">
        感谢每一位支持者！
      </p>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">
        所有赞助资金将用于游戏开发、美术资源采购和服务器维护。
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .sponsor-intro p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .sponsor-methods {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .sponsor-methods .nes-container {
    padding: 1.2rem;
  }

  .sponsor-methods .nes-container:has(.qrcode-img) {
    grid-column: span 1;
  }

  .method-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .method-icon {
    font-size: 2.5rem;
  }

  .method-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.8rem;
    color: #fff;
  }

  .method-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .modal-overlay.show {
    display: flex;
  }

  .modal-content {
    max-width: 280px;
    width: 100%;
    position: relative;
    text-align: center;
    padding: 1.5rem;
  }

  .modal-close {
    position: absolute;
    top: 0.5rem;
    right: 0.8rem;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .modal-close:hover {
    color: var(--accent);
  }

  .modal-qrcode {
    width: 180px;
    height: 180px;
    image-rendering: pixelated;
    border: 2px solid var(--border-color);
  }

  .sponsor-tiers {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tier-group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-color);
  }

  .tier-count {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .tier-group-footer {
    text-align: center;
    padding: 0.8rem;
    border: 1px dashed var(--border-color);
    margin-top: 0.5rem;
  }

  .tier-group-empty {
    text-align: center;
    padding: 1.5rem;
    border: 1px dashed var(--border-color);
  }

  .tier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1rem;
  }

  .tier-grid .nes-container {
    padding: 1rem;
  }

  .tier-card {
    text-align: center;
  }

  .tier-amount {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.9rem;
    color: #fff;
    margin-top: 0.5rem;
  }

  .sponsor-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .sponsor-list .nes-container {
    padding: 1rem;
  }

  .sponsor-member {
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    padding: 0.8rem;
  }

  .sponsor-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .sponsor-item.placeholder {
    opacity: 0.5;
    border: 1px dashed var(--border-color);
  }

  .sponsor-avatar {
    width: 48px;
    height: 48px;
    background: var(--accent2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', monospace;
    font-size: 1.2rem;
    min-width: 48px;
  }

  .sponsor-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.8rem;
    color: #fff;
    margin-bottom: 0.2rem;
  }

  .sponsor-link {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .sponsor-link:hover {
    color: var(--accent);
  }

  .sponsor-amount {
    display: inline-block;
    margin-top: 0.3rem;
    font-size: 0.85rem;
    color: #f7d44a;
    font-weight: bold;
  }

  .sponsor-role {
    font-size: 0.85rem;
    color: var(--accent);
    display: block;
    margin-bottom: 0.3rem;
  }

  .sponsor-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .thank-you {
    text-align: center;
    padding: 1rem;
  }

  @media (max-width: 640px) {
    .sponsor-methods,
    .tier-grid {
      grid-template-columns: 1fr;
    }

    .sponsor-list {
      grid-template-columns: 1fr;
    }
  }
</style>
