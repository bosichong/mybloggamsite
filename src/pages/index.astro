---
import BaseLayout from '../layouts/BaseLayout.astro';
import { features, chapters, bilibili, qqGroup } from '../config/site';
---

<BaseLayout title="首页">
  <section class="hero">
    <div class="hero-content">
      <div class="nes-container is-dark is-rounded">
        <div class="hero-text">
          <img src="/images/启动画面.png" alt="我的博客" class="hero-splash" />
          <h1 class="hero-title">我的博客</h1>
          <p class="hero-subtitle">一个互联网游民的博客成长之路</p>
          <p class="hero-desc">
            扮演一名博客站长，从2001年收到神秘邮件开始，<br />
            历经25年互联网风云，书写你的网络传奇。
          </p>
          <div class="hero-actions">
            <a href="/download" class="nes-btn is-success">⬇ 下载游戏</a>
            <a href="#features" class="nes-btn is-primary">★ 了解更多</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="video-section">
    <div class="nes-container is-dark">
      <div class="video-content">
        <div class="video-embed">
          <iframe src={`https://player.bilibili.com/player.html?bvid=${bilibili.bvid}&autoplay=0`} frameborder="0" allowfullscreen></iframe>
        </div>
        <div class="video-info">
          <p class="video-title">{bilibili.title}</p>
          <p class="video-desc">{bilibili.desc}</p>
          <a href={bilibili.url} target="_blank" class="nes-btn is-primary">在 B 站观看更多</a>
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="features-section">
    <h2 class="section-title"><span class="text-accent">■</span> 游戏特色</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="nes-container is-dark">
          <div class="feature-card">
            <span class="feature-icon">{f.icon}</span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="chapters-section">
    <h2 class="section-title"><span class="text-accent">■</span> 章节剧情</h2>
    <div class="timeline">
      {chapters.map((ch, i) => (
        <div class="nes-container is-dark chapter-card">
          <div class="chapter-header">
            <span class="nes-badge">
              <span class="is-dark">第{i + 1}章</span>
            </span>
            <span class="chapter-level">Lv.{ch.level}</span>
          </div>
          <h3 class="chapter-title">{ch.title}</h3>
          <p class="chapter-years">{ch.years}</p>
          <p class="chapter-desc">{ch.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2 class="section-title"><span class="text-accent">■</span> 关于游戏</h2>
    <div class="nes-container is-dark">
      <div class="about-content">
        <p>《我的博客》是一款关于独立博客经营的模拟经营游戏，使用 <strong>Godot 4.7</strong> 引擎和 <strong>GDScript</strong> 开发。</p>
        <p>游戏灵感来源于2000年代个人博客的黄金时代，致敬那些在互联网早期坚持写作的独立博客站长们。</p>
        <p>从撰写第一篇博文，到运营一个万人访问的独立博客；从自学编程，到开发开源项目；从文学青年，到出版畅销书作家——你的博客之路，由你书写。</p>
        <div class="about-tech">
          <span class="nes-text is-primary">Godot 4.7</span>
          <span class="nes-text is-success">GDScript</span>
          <span class="nes-text is-warning">Pixel Art</span>
          <span class="nes-text is-error">MIT License</span>
        </div>
        <div class="about-qq">
          <span class="qq-icon">💬</span>
          <span>游戏交流 QQ 群：</span>
          <strong class="qq-number">{qqGroup.number}</strong>
          <span class="nes-text is-disabled">{qqGroup.message}</span>
        </div>
      </div>
    </div>
    <div class="nes-container is-dark" style="margin-top: 1rem;">
      <div class="about-links">
        <a href="https://github.com/bosichong/MyBlogGame" target="_blank" class="nes-btn">GitHub</a>
        <a href="/download" class="nes-btn is-success">下载试玩</a>
        <a href="/sponsor" class="nes-btn is-error">赞助支持</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 2rem;
  }

  .hero-content .nes-container {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .hero-splash {
    max-width: 100%;
    height: auto;
    margin-bottom: 1rem;
    image-rendering: pixelated;
    border: 2px solid var(--border-color);
  }

  .hero-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 2.2rem;
    color: var(--accent);
    margin-bottom: 0.8rem;
    text-shadow: 3px 3px 0 #000;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-style: italic;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-light);
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-actions .nes-btn {
    font-size: 0.85rem;
    padding: 0.6rem 1.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .features-grid .nes-container {
    padding: 1.2rem;
  }

  .feature-card {
    text-align: center;
  }

  .feature-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .feature-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .feature-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chapter-card {
    padding: 1.2rem;
    border-left: 4px solid var(--accent);
  }

  .chapter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .chapter-level {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    color: var(--accent);
  }

  .chapter-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 0.3rem;
  }

  .chapter-years {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .chapter-desc {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.7;
  }

  .video-content {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 0.5rem;
  }

  .video-embed {
    flex: 0 0 auto;
    width: 400px;
    max-width: 100%;
  }

  .video-embed iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 2px solid var(--border-color);
  }

  .video-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .video-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.7rem;
    color: #fff;
    line-height: 1.4;
  }

  .video-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .video-content {
      flex-direction: column;
    }

    .video-embed {
      width: 100%;
    }
  }

  .about-content {
    padding: 0.5rem;
  }

  .about-content p {
    margin-bottom: 0.8rem;
    line-height: 1.6;
  }

  .about-tech {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .about-qq {
    margin-top: 1.2rem;
    padding: 0.8rem 1rem;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    flex-wrap: wrap;
  }

  .qq-icon {
    font-size: 1.2rem;
  }

  .qq-number {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.75rem;
    color: var(--accent);
  }

  .about-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.2rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .chapter-title {
      font-size: 0.65rem;
    }
  }
</style>
